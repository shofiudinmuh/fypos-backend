// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model Tenant {
  tenant_id                 String  @id @default(cuid())
  name                      String
  owner_email                String  @unique
  phone                     String?
  address                   String?
  business_type              String?

  trial_end_at                DateTime
  subscription_status        String
  subscription_plan_id        String?
  subscription_end_at         DateTime?
  grace_period_end_at          DateTime?


  created_at                 DateTime @default(now())
  updated_at                 DateTime?
  deleted_at                 DateTime?

  subscriptionPlans          SubscriptionPlan ? @relation(fields: [subscription_plan_id], references: [subscription_plan_id])

  subscriptionPayments      SubscriptionPayment[]
  outlets                   Outlet[]
  users                     User[]
  userPermissions           UserPermission[]
  offlineQueues             OfflineQueue[]

  activityLogs              ActivityLog[]
  apiLogs                   ApiLog[]
  shiftLogs                 ShiftLog[]
  auditLogs                 AuditLog[]

  @@map("tenants")
}

model SubscriptionPlan{
  subscription_plan_id  String @id @default(cuid())
  name                String
  price_monthly        Float
  price_yearly     Float
  billing_cycle    String
  max_users    Int @default(3)
  features    Json
  created_at   DateTime @default(now())
  updated_at   DateTime?
  deleted_at   DateTime?

  tenants    Tenant[]
  subscriptionPayments      SubscriptionPayment[]

  @@map("subscription_plans")
}

model SubscriptionPayment{
  subscription_payment_id String @id @default(cuid())
  tenant_id  String
  subscription_plan_id  String
  order_id   String @unique //Midtrans/ Zabbix order ID
  amount    Float
  status    String
  payment_type  String
  created_at    DateTime @default(now())
  settled_at    DateTime?

  tenant      Tenant @relation(fields: [tenant_id], references: [tenant_id])
  subscriptionPlan    SubscriptionPlan @relation(fields: [subscription_plan_id], references: [subscription_plan_id])

  @@index([tenant_id])
  @@map("subscription_payments")
}

model Outlet {
  outlet_id          String @id @default(cuid())
  tenant_id         String
  name              String
  address           String
  phone             String
  outlet_code        String @unique
  created_at         DateTime @default(now())
  updated_at         DateTime?
  deleted_at         DateTime?

  tenants           Tenant @relation(fields: [tenant_id], references: [tenant_id])
  users             User[]
  offlineQueues     OfflineQueue[]

  activityLogs          ActivityLog[]
  apiLogs               ApiLog[]
  shiftLogs             ShiftLog[]
  auditLogs             AuditLog[]

  @@index([tenant_id])
  @@map("outlets")
}

enum Role {
  OWNER
  ADMIN
  CASHIER
}

model Permission {
  permission_id         String @id @default(cuid())
  name                 String
  description          String
  created_at            DateTime @default(now())
  updated_at           DateTime?

  rolePermissions       RolePermission[]
  userPermissions       UserPermission[]

  @@map("permissions")
}

model RolePermission {
  role_permission_id        String @id @default(cuid())
  role                    Role
  permission_id            String

  permissions             Permission @relation(fields: [permission_id], references: [permission_id])

  @@map("role_permissions")
}

model UserPermission{
  user_permission_id        String @id @default(cuid())
  tenant_id                String
  user_id                  String
  permission_id            String
  granted_at               DateTime @default(now())
  granted_by               String?
  deleted_at               DateTime?

  users                   User @relation(fields: [user_id], references: [user_id])
  permissions             Permission @relation(fields: [permission_id], references: [permission_id])
  tenants                 Tenant @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id])
  @@map("user_permissions")
}

model Session {
  session_id         String @id @default(cuid())
  user_id            String
  device_info        String
  created_at         DateTime @default(now())
  expires_at         DateTime
  is_active          Boolean

  users           User @relation(fields: [user_id], references:[user_id])
  tokens          Token[]

  @@map("sessions")
}

model Token {
  token_id           String @id @default(cuid())
  user_id            String
  session_id         String
  token             String
  type              String
  expires_at         DateTime
  revoked_at         DateTime
  created_at         DateTime @default(now())
  updated_at         DateTime?

  users             User @relation(fields: [user_id], references: [user_id])
  sessions          Session @relation(fields: [session_id], references: [session_id])

  @@map("tokens")
}

model PasswordResetToken {
  reset_token_id        String @id @default(cuid())
  user_id              String
  token               String
  expires_at           DateTime
  created_at           DateTime @default(now())

  users               User @relation(fields: [user_id], references: [user_id])

  @@map("password_reset_tokens")
}

model User {
  user_id            String @id @default(cuid())
  tenant_id          String
  outlet_id         String
  name              String
  email             String @unique
  password_hash     String?
  pin               String?
  google_id         String?
  role              Role @default(CASHIER)
  is_active          Boolean @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime?
  deleted_at         DateTime?

  tenants           Tenant @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  outlets           Outlet @relation(fields: [outlet_id], references: [outlet_id], onDelete: Cascade)
  passwordResetTokens     PasswordResetToken[]
  sessions          Session[]
  tokens            Token[]
  userPermissions   UserPermission[]
  activityLogs      ActivityLog[]
  auditLogs         AuditLog[]
  shiftLogs         ShiftLog[]


  @@index([tenant_id])
  @@map("users")
}

model ShiftLog {
  shift_log_id            String @id @default(cuid())
  tenant_id              String
  outlet_id             String
  user_id                String
  start_time             DateTime
  end_time               DateTime
  start_cash             Decimal @db.Decimal(10,2)
  end_cash               Decimal @db.Decimal(10,2)

  tenants           Tenant @relation(fields: [tenant_id], references: [tenant_id])
  outlets           Outlet @relation(fields: [outlet_id], references: [outlet_id])
  users             User @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id, outlet_id])
  @@map("shift_logs")
}

model ActivityLog {
  activity_log_id         String @id @default(cuid())
  tenant_id              String
  outlet_id              String
  user_id                String
  action                String
  payload               Json?
  created_at             DateTime @default(now())

  tenants               Tenant @relation(fields: [tenant_id], references: [tenant_id])
  outlets               Outlet @relation(fields: [outlet_id], references: [outlet_id])
  users                 User @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id, outlet_id, created_at])
  @@map("activity_logs")
}

model ApiLog {
  api_log_id              String @id @default(cuid())
  tenant_id              String
  outlet_id              String
  method                String
  path                  String
  status_code            Int
  duration              Int
  created_at             DateTime @default(now())

  tenants               Tenant @relation(fields: [tenant_id], references: [tenant_id])
  outlets               Outlet @relation(fields: [outlet_id], references: [outlet_id])

  @@index([tenant_id, outlet_id, created_at])
  @@map("api_logs")
}

model AuditLog {
  audit_log_id            String @id @default(cuid())
  tenant_id              String
  outlet_id              String
  user_id                String
  action                String
  entity                String
  entity_id              String
  old_value              Json?
  new_value              Json?
  created_at             DateTime @default(now())

  tenants               Tenant @relation(fields: [tenant_id], references: [tenant_id])
  outlets               Outlet @relation(fields: [outlet_id], references: [outlet_id])
  users                 User @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id,outlet_id, created_at])
  @@map("audit_logs")
}

model OfflineQueue {
  offline_queue_id        String @id @default(cuid())
  tenant_id              String
  outlet_id              String
  type                  String
  payload               Json
  status                String @default("PENDING")
  created_at             DateTime @default(now())

  tenants               Tenant @relation(fields: [tenant_id], references: [tenant_id])
  outlets               Outlet @relation(fields: [outlet_id], references: [outlet_id])

  @@index([tenant_id, outlet_id, status])
  @@map("offline_queues")
}